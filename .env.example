# API Configuration
# Relative path used by the frontend (proxied in dev, must match backend endpoint)
VITE_API_URL=/api/v1

# Project slug to load (determines which project data to fetch)
VITE_PROJECT_SLUG=loteoamvt

# Available project slugs:
# - loteoamvt (Loteo project for testing)
# - torre-encuentro (Building project - Torre Encuentro)
# - amvt (Most complete project data)

# Optional: Override API URL for build-time meta tag generation
# Defaults to:
#   - Development: http://localhost:8080/api/v1
#   - Production: https://real-state-api-mu32.onrender.com/api/v1
# BUILD_API_URL=http://localhost:8080/api/v1
