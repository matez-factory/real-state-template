# API Configuration
# Relative path used by the frontend (proxied in dev, must match backend endpoint)
VITE_API_URL=/api/v1

# Project slug to load (determines which project data to fetch)
VITE_PROJECT_SLUG=loteoamvt

# Available project slugs:
# - loteoamvt (Loteo project for testing)
# - torre-encuentro (Building project - Torre Encuentro)
# - amvt (Most complete project data)

# Optional: Override API URL for build-time meta tag generation
# Defaults to: http://localhost:8080/api/v1 (local API)
#
# For production builds on Vercel/CI, set this environment variable to:
# BUILD_API_URL=https://real-state-api-mu32.onrender.com/api/v1
#
# This ensures:
#   - Local dev (npm run dev): uses localhost:8080 ✓
#   - Local build (npm run build): uses localhost:8080 ✓
#   - Vercel build: uses production API (when BUILD_API_URL is set) ✓
